# Supabase public browser configuration.
# Use the publishable key for new Supabase projects.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional compatibility alias for older Supabase project dashboards.
# The app prefers NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY when both are set.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only OpenAI configuration. Never expose this as NEXT_PUBLIC_*.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
